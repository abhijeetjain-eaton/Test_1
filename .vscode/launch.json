{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug file_reader (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/file_reader",
            "args": [
                "${workspaceFolder}/data/sample.txt"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for GDB",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build (Debug)",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug file_reader (LLDB – macOS)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/file_reader",
            "args": [
                "${workspaceFolder}/data/sample.txt"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "CMake Build (Debug)"
        },
        {
            "name": "Debug file_reader (MSVC – Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/file_reader.exe",
            "args": [
                "${workspaceFolder}/data/sample.txt"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake Build (Debug)"
        }
    ]
}
